--// SAVE SYSTEM
local FILE = "UI_Save.json"
local data = { 
    Toggles = {},
    Settings = {
        ToggleKey = "LeftControl"
    }
}

if isfile and isfile(FILE) then
    local ok, res = pcall(function() return HttpService:JSONDecode(readfile(FILE)) end)
    if ok and res then 
        -- Merge loaded data to ensure nested tables exist
        if res.Toggles then data.Toggles = res.Toggles end
        if res.Settings then data.Settings = res.Settings end
    end
end

local function save()
    if writefile then writefile(FILE, HttpService:JSONEncode(data)) end
end

