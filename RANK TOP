--// SERVICES
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer

--// SAVE SYSTEM
local FILE = "UI_Save.json"
local data = { 
    Toggles = {},
    Settings = { ToggleKey = "LeftControl", WalkSpeed = 16 }
}

if isfile and isfile(FILE) then
    local ok, res = pcall(function() return HttpService:JSONDecode(readfile(FILE)) end)
    if ok and res then 
        if res.Toggles then data.Toggles = res.Toggles end
        if res.Settings then data.Settings = res.Settings end
    end
end

local function save()
    if writefile then pcall(function() writefile(FILE, HttpService:JSONEncode(data)) end) end
end

--// REMOTES
local UpgradeRemote = nil
task.spawn(function()
    while not UpgradeRemote do
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if remotes then
            local upgrade = remotes:FindFirstChild("Upgrade")
            if upgrade then UpgradeRemote = upgrade:FindFirstChild("RequestUpgrade") end
        end
        task.wait(1)
    end
end)

local RuneRemote = nil
task.spawn(function()
    while not RuneRemote do
        for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
            if v.Name == "RequestRuneRoll" and v:IsA("RemoteEvent") then
                RuneRemote = v
                break
            end
        end
        task.wait(1)
    end
end)

