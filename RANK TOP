-- TOGGLE CREATOR
local function createToggle(parent, text, key)
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(1, -10, 0, 35)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", holder)
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.Gotham
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left

    local btn = Instance.new("TextButton", holder)
    btn.Size = UDim2.new(0, 45, 0, 20)
    btn.Position = UDim2.new(1, -50, 0.5, -10)
    btn.Text = ""
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    Instance.new("UICorner", btn)

    local function set(v)
        data.Toggles[key] = v
        save()
        btn.BackgroundColor3 = v and Color3.fromRGB(0, 180, 130) or Color3.fromRGB(50, 50, 55)
        
        if v then
            task.spawn(function()
                while data.Toggles[key] do
                    if UpgradeRemote then
                        pcall(function() UpgradeRemote:FireServer(key, "Max") end)
                    end
                    task.wait(0.5)
                end
            end)
        end
    end

    set(data.Toggles[key] or false)
    btn.MouseButton1Click:Connect(function() set(not data.Toggles[key]) end)
end

