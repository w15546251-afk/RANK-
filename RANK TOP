-- TOGGLE CREATOR
local function createToggle(parent, text, key)
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(1, -10, 0, 35)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", holder)
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.Gotham
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left

    local btn = Instance.new("TextButton", holder)
    btn.Size = UDim2.new(0, 45, 0, 20)
    btn.Position = UDim2.new(1, -50, 0.5, -10)
    btn.Text = ""
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    Instance.new("UICorner", btn)

    local state = data.Toggles[key] or false

    local function set(v)
        state = v
        data.Toggles[key] = v
        save()
        btn.BackgroundColor3 = v and Color3.fromRGB(0, 180, 130) or Color3.fromRGB(50, 50, 55)
        if v then
            task.spawn(function()
                while data.Toggles[key] do
                    UpgradeRemote:FireServer(key, "Max")
                    task.wait(0.3)
                end
            end)
        end
    end

    set(state)
    btn.MouseButton1Click:Connect(function() set(not state) end)
end

-- KEYBIND SETTING CREATOR
local function createKeybindSetting(parent)
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(1, -10, 0, 40)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", holder)
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Text = "Menu Keybind:"
    label.TextColor3 = Color3.new(1, 1, 1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left

    local bindBtn = Instance.new("TextButton", holder)
    bindBtn.Size = UDim2.new(0, 80, 0, 30)
    bindBtn.Position = UDim2.new(1, -85, 0.5, -15)
    bindBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    bindBtn.Text = data.Settings.ToggleKey
    bindBtn.TextColor3 = Color3.fromRGB(0, 200, 255)
    Instance.new("UICorner", bindBtn)

    local listening = false

    bindBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        bindBtn.Text = "..."
        bindBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        
        local connection
        connection = UIS.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Keyboard then
                data.Settings.ToggleKey = i.KeyCode.Name
                bindBtn.Text = i.KeyCode.Name
                bindBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
                save()
                connection:Disconnect()
                task.wait(0.1)
                listening = false
            end
        end)
    end)
end

